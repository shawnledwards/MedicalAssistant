# ── Server ────────────────────────────────────────────────────────
PORT=7860

# ── Model ─────────────────────────────────────────────────────────
MODEL_REPO_ID=TheBloke/Mistral-7B-Instruct-v0.2-GGUF
MODEL_FILENAME=mistral-7b-instruct-v0.2.Q4_K_M.gguf
MODEL_PATH=models/mistral-7b-instruct-v0.2.Q4_K_M.gguf

# GPU layers:
#   0  = CPU-only (HF Spaces free tier)
#   35 = full GPU offload on RTX 3070 (Q4_K_M fits in 8 GB VRAM)
#   35 = also works for Q6_K if you switch MODEL_FILENAME above
N_GPU_LAYERS=0

# ── Model context ─────────────────────────────────────────────────
N_CTX=5000
N_BATCH=512

# ── LLM backend ───────────────────────────────────────────────────
# llama_cpp = local GPU/CPU inference (default for local dev)
# groq      = Groq cloud API (recommended for HF Spaces)
LLM_BACKEND=llama_cpp

# ── Groq (required when LLM_BACKEND=groq) ────────────────────────
# Set GROQ_API_KEY as an HF Spaces secret, not in this file
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Embeddings ────────────────────────────────────────────────────
EMBEDDING_MODEL=thenlper/gte-large

# ── Data paths ────────────────────────────────────────────────────
PDF_PATH=data/medical_diagnosis_manual.pdf
VECTOR_DB_PATH=data/vectorstore
